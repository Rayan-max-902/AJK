{
  "entities": {
    "Event": {
      "title": "Event",
      "description": "A school event or competition",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Open", "Closed", "Coming Soon"] },
        "participationEnabled": { "type": "boolean" },
        "participantCount": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["title", "description", "status", "participationEnabled"]
    },
    "Project": {
      "title": "Project",
      "description": "A student or school project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["title", "description"]
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website content",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSlogan": { "type": "string" },
        "mission": { "type": "string" },
        "vision": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/events/{eventId}": {
      "schema": "Event",
      "description": "Collection of school events"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Showcase of school projects"
    },
    "/settings/main": {
      "schema": "SiteSettings",
      "description": "Global configuration and text content"
    }
  }
}
